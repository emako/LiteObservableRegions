<Window
    x:Class="LiteObservableRegions.WPF.Test.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LiteObservableRegions.WPF.Test"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:r="http://schemas.github.com/liteobservableregions/2026/xaml"
    xmlns:view="clr-namespace:LiteObservableRegions.WPF.Test.Views"
    Title="LiteObservableRegions.WPF.Test"
    Width="860"
    Height="600"
    mc:Ignorable="d">
    <Grid RowDefinitions="Auto,*">
        <StackPanel
            Margin="0,20,0,10"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                x:Name="BtnA"
                Width="120"
                Height="40"
                Margin="10"
                Click="BtnA_Click"
                Content="Navigate A" />
            <Button
                x:Name="BtnB"
                Width="120"
                Height="40"
                Margin="10"
                Click="BtnB_Click"
                Content="Navigate B" />
            <Button
                x:Name="BtnRedirect"
                Width="120"
                Height="40"
                Margin="10"
                Click="BtnRedirect_Click"
                Content="Redirect A" />
            <Button
                x:Name="BtnBack"
                Width="120"
                Height="40"
                Margin="10"
                Click="BtnBack_Click"
                Content="GoBack" />
            <Button
                x:Name="BtnForward"
                Width="120"
                Height="40"
                Margin="10"
                Click="BtnForward_Click"
                Content="GoForward" />
            <Button
                x:Name="BtnTest"
                Width="120"
                Height="40"
                Margin="10"
                Click="BtnTest_Click"
                Content="Test..." />
        </StackPanel>
        <!--  DependencyInjection View  -->
        <!--<ContentControl Grid.Row="1" r:ObservableRegion.RegionName="region://MainGridRegion" />-->
        <!--  Named View  -->
        <Grid Grid.Row="1" r:ObservableRegion.RegionName="region://MainGridRegion">
            <view:PageA r:ObservableRegion.RegionName="region://GridA" r:ObservableRegion.ViewName="region://MainGridRegion/GridA" />
            <view:PageB r:ObservableRegion.RegionName="region://GridB" r:ObservableRegion.ViewName="region://MainGridRegion/GridB" />
        </Grid>
    </Grid>
</Window>
